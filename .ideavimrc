set clipboard=unnamedplus
set number
set relativenumber
set shiftwidth=2
set tabstop=2
set softtabstop=2
set expandtab

let mapleader = " "
nnoremap <Tab> :bnext<CR>
nnoremap <S-Tab> :bprevious<CR>

nnoremap <c-up> <c-w>2-
nnoremap <c-down> <c-w>2+
nnoremap <c-left> <c-w>2<
nnoremap <c-right> <c-w>2>
