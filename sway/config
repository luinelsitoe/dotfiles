#MY-CONFIG=====================================================
#volume
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/.config/scripts/volume_up.sh
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

#mic volume
# Aumenta o volume do microfone em 5% usando Shift + XF86AudioRaiseVolume
bindsym Shift+XF86AudioRaiseVolume exec --no-startup-id amixer sset Capture 5%+

# Diminui o volume do microfone em 5% usando Shift + XF86AudioLowerVolume
bindsym Shift+XF86AudioLowerVolume exec --no-startup-id amixer sset Capture 5%-

#network
bindsym Control+Mod1+i exec --no-startup-id ~/.config/scripts/wlan_connect.sh

#set rofi binding
bindsym Mod4+d exec "wofi --show drun"
bindsym Mod4+Shift+d exec "wofi --show run"

#set brightness binding
bindsym XF86MonBrightnessDown exec --no-startup-id sudo brightnessctl set 5%-
bindsym XF86MonBrightnessUp exec --no-startup-id sudo brightnessctl set 5%+

