#configuring colors
# target                 title     bg    text   indicator  border
client.focused           $surface2 $base $text  $teal      $teal
client.focused_inactive  $base     $base $text  $surface2  $surface2
client.unfocused         $base     $base $text  $surface2  $surface2
client.urgent            $peach    $base $peach $base      $base
client.placeholder       $overlay0 $base $text  $base      $base
client.background        $base

# Add gaps
gaps inner 6
gaps outer 3

#Borders thickness (para voltar ao normal coloque border normal)
for_window [class=".*"] border pixel 0
