{
  "layer": "top",
    "position": "top",
    "output": ["*"],
    "height": 24,
    "spacing": 5,

    "modules-left": ["hyprland/workspaces", "memory", "cpu"],
    "modules-center": ["clock"],
    "modules-right": ["hyprland/language", "custom/notification" , "idle_inhibitor", "wireplumber", "network", "battery", "tray"],

    "hyprland/workspaces": {
      "format": "{name}",
      "on-click": "activate",
      "sort-by-number": true,
      "persistent-workspaces": {
        "1": [],
        "2": [],
        "3": [],
        "4": []
      }
    },

    "clock": {
      "format": "{:%d.%m.%Y | %H:%M}"
    },

    "wireplumber": {
      "format": "{icon} {volume}%",
      "format-muted": "’Ć”",
      "on-click": "helvum",
      "format-icons": ["’Ć”", "’Ć¦", "’Ć©"]
    },

    "battery": {
      "interval": 1,
      "bat": "BAT0",
      "interval": 60,
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
      "max-length": 25
    },

    "memory": {
      "interval": 10,
      "format": "’āē {used:0.1f}G "
    },

    "cpu": {
      "interval": 1,
      "format": "’ŗø {usage}% ",
      "max-length": 10
    },

    "network": {
      "interval": 1,
      "format": "",
      "format-ethernet": "\udb83\udc9d ({bandwidthDownBytes})",
      "format-wifi": "{icon} ({bandwidthDownBytes})",
      "format-disconnected": "\udb83\udc9c",
      "format-icons": ["\udb82\udd2f", "\udb82\udd1f", "\udb82\udd22", "\udb82\udd25", "\udb82\udd28"],
      "tooltip-format-wifi": "{essid} ({signalStrength}%)",
      "tooltip-format-ethernet": "{ifname}",
      "tooltip-format-disconnected": "Disconnected",
    },

    "custom/notification": {
      "tooltip": false,
      "format": "{} {icon}",
      "format-icons": {
        "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
        "none": "’éó",
        "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
        "dnd-none": "’ćĘ",
        "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
        "inhibited-none": "’éó",
        "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
        "dnd-inhibited-none": "’ćĘ"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
    },

    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "’ü«  ",
        "deactivated": "’ü░  "
      }
    },

    "hyprland/language": {
      "format": "{short}"
    },

    "tray": {
      "icon-size": 16,
      "spacing": 16
    }
}
