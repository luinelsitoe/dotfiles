{
    "layer": "bottom",
    "position": "top",
    "height": 30,

    "modules-left": ["sway/mode", "sway/workspaces", "sway/window"],
    "modules-center": [],
    "modules-right": ["cpu","memory", "pulseaudio", "network", "battery", "clock", "custom/notification", "idle_inhibitor", "tray"],
    "sway/mode": {
        "format": "’üö {}"
    },
    "sway/workspaces": {
        "format": "{name}",
        "disable-scroll": true
